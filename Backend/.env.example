# Copy this file to Backend/.env and add your real OpenAI API key.
# Never commit Backend/.env.

OPENAI_API_KEY=your-openai-api-key-here

# Optional overrides
PORT=8787
SITECLAW_HOST=127.0.0.1
SITECLAW_MAX_JSON_BODY_BYTES=10000000
SITECLAW_MAX_PUBLISHED_SITE_BYTES=5000000
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TOKEN_TTL_SECONDS=600
OPENAI_GENERATION_MODEL=gpt-5.4-mini

# Use * for local native-app development. Set a specific origin for a web app.
SITECLAW_ALLOWED_ORIGIN=*
