# Copy this file to Backend/.env and add your real OpenAI API key.
# Never commit Backend/.env.

OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional overrides
PORT=8787
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TOKEN_TTL_SECONDS=600
OPENAI_GENERATION_MODEL=gpt-5.4-mini

# Use * for local native-app development. Set a specific origin for a web app.
SITECLAW_ALLOWED_ORIGIN=*

# Supabase public auth config. These are public/anon values, not service-role secrets.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe backend-only billing config. Never put these in the native app.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PRICE_STARTER=price_starter_19_monthly
STRIPE_PRICE_PRO=price_pro_79_monthly
SITECLAW_APP_URL=http://localhost:3000
